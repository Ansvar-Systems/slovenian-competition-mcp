{
  "name": "@ansvar/slovenian-competition-mcp",
  "version": "0.1.0",
  "mcpName": "eu.ansvar/slovenian-competition-mcp",
  "description": "AVK (Agencija za varstvo konkurence \u2014 Slovenian Competition Protection Agency) MCP server \u2014 competition law decisions, merger control, and sector enforcement",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "slovenian-competition-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "server.json"
  ],
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/slovenian-competition-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/slovenian-competition-mcp/issues"
  },
  "homepage": "https://github.com/Ansvar-Systems/slovenian-competition-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "avk",
    "slovenian-competition",
    "competition-law",
    "antitrust",
    "merger-control",
    "slovenia",
    "compliance",
    "ansvar"
  ],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/http-server.ts",
    "start": "node dist/http-server.js",
    "seed": "npx tsx scripts/seed-sample.ts",
    "ingest": "npx tsx scripts/ingest-avk.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "tsc --noEmit",
    "coverage:update": "tsx scripts/update-coverage.ts",
    "coverage:verify": "tsx scripts/verify-coverage.ts",
    "test:contract": "echo \"No contract tests yet\" && exit 0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "cheerio": "^1.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "better-sqlite3": "^12.10.0",
    "zod": "^3.22.4"
  }
